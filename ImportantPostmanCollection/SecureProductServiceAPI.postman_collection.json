          "name": "Add Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Product created with correct data', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.success).to.eql(true);",
                  "    pm.expect(json.data.productName).to.eql('Wireless Keyboard');",
                  "    pm.expect(json.data.price).to.eql(79.99);",
                  "    pm.expect(json.data.quantity).to.eql(100);",
                  "});",
                  "",
                  "pm.test('Product has an assigned ID', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.data.productId).to.be.a('number');",
                  "    // Save for use in Update / Delete requests",
                  "    pm.collectionVariables.set('productId', json.data.productId);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
